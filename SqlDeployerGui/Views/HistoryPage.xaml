<Page
    x:Class="SqlDeployerGui.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:sql="using:SqlDeployer">

    <Grid Padding="28,24,28,28" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row: title + subtitle on the left, refresh on the right -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="History" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource Subtle}" />
            </StackPanel>
            <Button Grid.Column="1" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Records table inside a card surface -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="20,14" ColumnSpacing="12"
                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SCRIPT" Style="{StaticResource SectionCaption}" />
                    <TextBlock Grid.Column="1" Text="VERSION" Style="{StaticResource SectionCaption}" />
                    <TextBlock Grid.Column="2" Text="DEPLOYED (UTC)" Style="{StaticResource SectionCaption}" />
                    <TextBlock Grid.Column="3" Text="STATUS" Style="{StaticResource SectionCaption}" />
                </Grid>

                <ListView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None"
                          Padding="8,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="12,6" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="sql:DeploymentHistory">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind ScriptName}"
                                           TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Version}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{x:Bind DeployedAt}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{x:Bind Success}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
