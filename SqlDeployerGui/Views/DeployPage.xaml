<Page
    x:Class="SqlDeployerGui.Views.DeployPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:SqlDeployerGui.Converters"
    xmlns:models="using:SqlDeployer.Models"
    xmlns:anim="using:Microsoft.UI.Xaml.Media.Animation">

    <Page.Resources>
        <conv:BoolNegationConverter x:Key="Not" />
        <conv:LogKindToBrushConverter x:Key="LogBrush" />
        <conv:LogKindToSeverityConverter x:Key="Severity" />

        <!-- Blinking terminal caret -->
        <Storyboard x:Key="BlinkCaret" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Caret"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.55" Value="0" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.1" Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Terminal log list: monospace, transparent over the dark surface -->
        <Style x:Key="TerminalList" TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="SelectionMode" Value="None" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Deploy" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Run pending SQL migration scripts against a target database."
                       Style="{StaticResource Subtle}" />
        </StackPanel>

        <!-- Two-pane body: controls on the left, live output filling the right -->
        <Grid x:Name="ContentRoot" Grid.Row="1" ColumnSpacing="20" RowSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FormColumn" Width="404" />
                <ColumnDefinition x:Name="OutputColumn" Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="FormRow" Height="*" />
                <RowDefinition x:Name="OutputRowNarrow" Height="0" />
            </Grid.RowDefinitions>

            <!-- LEFT: connection form, actions, result, progress -->
            <ScrollViewer x:Name="FormPane" Grid.Column="0" Grid.Row="0"
                          VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel Spacing="{StaticResource StackSpacingM}">

                    <Border Style="{StaticResource Card}">
                        <StackPanel Spacing="{StaticResource StackSpacingS}">
                            <TextBlock Text="CONNECTION" Style="{StaticResource SectionCaption}" />

                            <AutoSuggestBox x:Name="ServerBox" Header="Server"
                                            PlaceholderText="localhost\SQLEXPRESS"
                                            Text="{Binding Server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding IsIdle}"
                                            TextChanged="ServerBox_TextChanged"
                                            SuggestionChosen="ServerBox_SuggestionChosen"
                                            QuerySubmitted="ServerBox_QuerySubmitted"
                                            GotFocus="ServerBox_GotFocus" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Header="Login"
                                         PlaceholderText="Windows auth"
                                         Text="{Binding Login, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsIdle}" />
                                <PasswordBox Grid.Column="1" Header="Password"
                                             PlaceholderText="Password"
                                             Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsIdle}" />
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <AutoSuggestBox x:Name="DatabaseBox" Grid.Column="0" Header="Database"
                                                PlaceholderText="Target database name"
                                                Text="{Binding Database, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                IsEnabled="{Binding IsIdle}"
                                                TextChanged="DatabaseBox_TextChanged"
                                                SuggestionChosen="DatabaseBox_SuggestionChosen"
                                                GotFocus="DatabaseBox_GotFocus" />
                                <Button Grid.Column="1" Content="&#xE72C;" FontFamily="Segoe Fluent Icons"
                                        Height="32" MinHeight="32" Width="40" Padding="0"
                                        VerticalAlignment="Bottom"
                                        ToolTipService.ToolTip="Load databases from server"
                                        Command="{Binding LoadDatabasesCommand}"
                                        IsEnabled="{Binding IsIdle}" />
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Header="Script path"
                                         PlaceholderText="Folder with .sql migration scripts"
                                         Text="{Binding ScriptPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsIdle}" />
                                <Button Grid.Column="1" Content="Browse" Height="32" MinHeight="32"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding BrowseCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Primary actions -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Test Connection"
                                HorizontalAlignment="Stretch"
                                Command="{Binding TestConnectionCommand}"
                                IsEnabled="{Binding IsIdle}" />
                        <Button Grid.Column="1" Content="Deploy"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding DeployCommand}"
                                IsEnabled="{Binding IsIdle}" />
                        <Button Grid.Column="2" Content="Cancel"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding IsBusy}" />
                    </Grid>

                    <!-- Inline result banner: directly under the actions so the
                         success/error message is visible without scrolling. -->
                    <muxc:InfoBar IsOpen="{Binding IsResultOpen, Mode=TwoWay}"
                                  Severity="{Binding ResultKind, Converter={StaticResource Severity}}"
                                  Message="{Binding ResultMessage}"
                                  IsClosable="True" />

                    <!-- Live progress: bar + percentage -->
                    <StackPanel Spacing="6">
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding ProgressMax}"
                                     Value="{Binding ProgressValue}" />
                        <TextBlock Text="{Binding ProgressText}"
                                   Style="{StaticResource Subtle}" FontSize="12" />
                    </StackPanel>

                    <!-- Re-run option: bypass deployment history -->
                    <StackPanel Spacing="2">
                        <CheckBox Content="Re-run already-deployed scripts"
                                  IsChecked="{Binding ForceRerun, Mode=TwoWay}"
                                  IsEnabled="{Binding IsIdle}" />
                        <TextBlock Text="Ignores history and runs every .sql file again. Use only for scripts that are safe to re-apply."
                                   Style="{StaticResource Subtle}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,0" />
                        <CheckBox Content="Auto-order scripts by foreign keys"
                                  IsChecked="{Binding AutoOrderByDependencies, Mode=TwoWay}"
                                  IsEnabled="{Binding IsIdle}" Margin="0,8,0,0" />
                        <TextBlock Text="Detects parent/child table dependencies and runs parents first. Turn off to run in folder + name order only."
                                   Style="{StaticResource Subtle}" FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT: terminal-style live output, fills available height -->
            <Border x:Name="OutputPane" Grid.Column="1" Grid.Row="0"
                    Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="20,16,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="OUTPUT" Style="{StaticResource SectionCaption}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="CopyOutput_Click"
                                ToolTipService.ToolTip="Copy output to clipboard">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                <TextBlock Text="Copy" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Dark terminal surface: forced Dark theme so it always reads
                         as a console regardless of the app's light/dark setting. -->
                    <Border Grid.Row="1" Margin="12,0,12,12" CornerRadius="6"
                            Background="{ThemeResource ConsoleBackgroundBrush}"
                            BorderBrush="{ThemeResource ConsoleBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <muxc:Pivot x:Name="OutputPivot" Grid.Row="0" Padding="8,0,8,0">
                                <muxc:Pivot.Resources>
                                    <x:Double x:Key="PivotHeaderItemFontSize">14</x:Double>
                                </muxc:Pivot.Resources>
                                <muxc:PivotItem>
                                    <muxc:PivotItem.Header>
                                        <TextBlock Text="{x:Bind Vm.SuccessHeader, Mode=OneWay}" FontSize="14" />
                                    </muxc:PivotItem.Header>
                                    <ListView x:Name="SuccessList" Style="{StaticResource TerminalList}"
                                              ItemsSource="{Binding SuccessLog}">
                                        <ListView.ItemContainerTransitions>
                                            <TransitionCollection>
                                                <anim:AddDeleteThemeTransition />
                                                <anim:EntranceThemeTransition FromVerticalOffset="8" />
                                            </TransitionCollection>
                                        </ListView.ItemContainerTransitions>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:LogEntry">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                               FontSize="11" VerticalAlignment="Top" Margin="0,3,0,0"
                                                               Foreground="{Binding Kind, Converter={StaticResource LogBrush}}" />
                                                    <TextBlock Text="{x:Bind Message}" FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="13"
                                                               Foreground="{Binding Kind, Converter={StaticResource LogBrush}}"
                                                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </muxc:PivotItem>
                                <muxc:PivotItem>
                                    <muxc:PivotItem.Header>
                                        <TextBlock Text="{x:Bind Vm.ErrorHeader, Mode=OneWay}" FontSize="14" />
                                    </muxc:PivotItem.Header>
                                    <ListView x:Name="ErrorList" Style="{StaticResource TerminalList}"
                                              ItemsSource="{Binding ErrorLog}">
                                        <ListView.ItemContainerTransitions>
                                            <TransitionCollection>
                                                <anim:AddDeleteThemeTransition />
                                                <anim:EntranceThemeTransition FromVerticalOffset="8" />
                                            </TransitionCollection>
                                        </ListView.ItemContainerTransitions>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:LogEntry">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="&#xEB90;" FontFamily="Segoe Fluent Icons"
                                                               FontSize="11" VerticalAlignment="Top" Margin="0,3,0,0"
                                                               Foreground="{Binding Kind, Converter={StaticResource LogBrush}}" />
                                                    <TextBlock Text="{x:Bind Message}" FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="13"
                                                               Foreground="{Binding Kind, Converter={StaticResource LogBrush}}"
                                                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </muxc:PivotItem>
                            </muxc:Pivot>

                            <!-- Terminal prompt line with a blinking caret -->
                            <Border Grid.Row="1" Background="{ThemeResource ConsolePromptBackgroundBrush}" Padding="16,8"
                                    BorderBrush="{ThemeResource ConsoleBorderBrush}" BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="&#x276F;" FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                               Foreground="{ThemeResource ConsolePromptArrowBrush}" />
                                    <TextBlock Text="{Binding Status}" FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                               Foreground="{ThemeResource ConsoleStatusBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="Caret" Text="&#x2588;" FontFamily="Cascadia Mono, Consolas"
                                               FontSize="13" Foreground="{ThemeResource ConsoleCaretBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Collapse to a single stacked column on narrow windows -->
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="WideLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="900" />
                        </VisualState.StateTriggers>
                    </VisualState>
                    <VisualState x:Name="NarrowLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="FormColumn.Width" Value="*" />
                            <Setter Target="OutputColumn.Width" Value="0" />
                            <Setter Target="FormRow.Height" Value="Auto" />
                            <Setter Target="OutputRowNarrow.Height" Value="*" />
                            <Setter Target="OutputPane.(Grid.Column)" Value="0" />
                            <Setter Target="OutputPane.(Grid.Row)" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </Grid>
</Page>
