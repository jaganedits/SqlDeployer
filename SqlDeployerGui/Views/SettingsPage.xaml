<Page
    x:Class="SqlDeployerGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="28,24,28,28" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="560" HorizontalAlignment="Left">
            <StackPanel Spacing="2">
                <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Preferences and saved connection behavior."
                           Style="{StaticResource Subtle}" />
            </StackPanel>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="14">
                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionCaption}" />
                    <ComboBox Header="Theme" Width="240"
                              ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="10">
                    <TextBlock Text="SAVED CONNECTION" Style="{StaticResource SectionCaption}" />
                    <TextBlock Text="Connection details — except the password — are remembered between sessions. Passwords are never saved to disk."
                               Style="{StaticResource Subtle}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
