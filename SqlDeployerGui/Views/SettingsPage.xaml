<Page
    x:Class="SqlDeployerGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:conv="using:SqlDeployerGui.Converters">

    <Page.Resources>
        <conv:BoolNegationConverter x:Key="Not" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer Padding="{StaticResource PagePadding}" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="4" HorizontalAlignment="Stretch">

            <StackPanel Spacing="2" Margin="0,0,0,16">
                <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Preferences, saved connection behavior, and app info."
                           Style="{StaticResource Subtle}" />
            </StackPanel>

            <!-- ============ APPEARANCE ============ -->
            <tk:SettingsExpander Header="Appearance"
                                 Description="Theme and accent color"
                                 IsExpanded="True">
                <tk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE790;" />
                </tk:SettingsExpander.HeaderIcon>

                <!-- Theme as the inline (right-aligned) control on the header row -->
                <ComboBox MinWidth="160"
                          ItemsSource="{Binding Themes}"
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />

                <tk:SettingsExpander.Items>
                    <tk:SettingsCard Header="Accent color"
                                     Description="Pick a preset, or choose a custom color.">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button x:Name="SwAzure" Tag="Azure" Click="AccentSwatch_Click"
                                    Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="14"
                                    Background="#2F6FED" ToolTipService.ToolTip="Azure"
                                    IsEnabled="{Binding FollowSystemAccent, Converter={StaticResource Not}}" />
                            <Button x:Name="SwEmerald" Tag="Emerald" Click="AccentSwatch_Click"
                                    Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="14"
                                    Background="#10B981" ToolTipService.ToolTip="Emerald"
                                    IsEnabled="{Binding FollowSystemAccent, Converter={StaticResource Not}}" />
                            <Button x:Name="SwIndigo" Tag="Indigo" Click="AccentSwatch_Click"
                                    Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="14"
                                    Background="#7C5CFC" ToolTipService.ToolTip="Indigo"
                                    IsEnabled="{Binding FollowSystemAccent, Converter={StaticResource Not}}" />
                            <Button x:Name="SwAmber" Tag="SlateAmber" Click="AccentSwatch_Click"
                                    Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="14"
                                    Background="#F59E0B" ToolTipService.ToolTip="Slate-Amber"
                                    IsEnabled="{Binding FollowSystemAccent, Converter={StaticResource Not}}" />
                            <Button Width="28" Height="28" MinWidth="0" MinHeight="0" Padding="0" CornerRadius="14"
                                    ToolTipService.ToolTip="Custom color"
                                    IsEnabled="{Binding FollowSystemAccent, Converter={StaticResource Not}}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F85149" Offset="0" />
                                        <GradientStop Color="#2F6FED" Offset="0.5" />
                                        <GradientStop Color="#10B981" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Flyout>
                                    <Flyout>
                                        <muxc:ColorPicker x:Name="CustomPicker"
                                                          ColorSpectrumShape="Ring"
                                                          IsMoreButtonVisible="True"
                                                          IsColorChannelTextInputVisible="True"
                                                          IsAlphaEnabled="False"
                                                          ColorChanged="CustomPicker_ColorChanged" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Subtle}" FontSize="12"
                                       Text="{Binding SelectedAccentPreset}" />
                        </StackPanel>
                    </tk:SettingsCard>

                    <tk:SettingsCard Header="Follow system accent color"
                                     Description="Use the accent color set in Windows.">
                        <ToggleSwitch IsOn="{Binding FollowSystemAccent, Mode=TwoWay}" />
                    </tk:SettingsCard>
                </tk:SettingsExpander.Items>
            </tk:SettingsExpander>

            <!-- ============ SAVED CONNECTION ============ -->
            <tk:SettingsExpander Header="Saved connections"
                                 Description="Load a saved server onto the Deploy form, or remove it"
                                 IsExpanded="True">
                <tk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE72E;" />
                </tk:SettingsExpander.HeaderIcon>
                <tk:SettingsExpander.ItemsHeader>
                    <StackPanel>
                        <!-- Empty state -->
                        <TextBlock Padding="16,12" TextWrapping="Wrap" Style="{StaticResource Subtle}"
                                   Visibility="{Binding HasSavedConnections, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                   Text="No saved connections yet. After a successful Test Connection on the Deploy page, the server is remembered here (password encrypted with Windows DPAPI)." />

                        <!-- List of saved connections -->
                        <ItemsControl ItemsSource="{Binding SavedConnections}"
                                      Visibility="{Binding HasSavedConnections, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="16,10" ColumnSpacing="12"
                                          BorderThickness="0,0,0,1"
                                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" Glyph="&#xE968;" FontSize="16"
                                                  VerticalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Server}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Style="{StaticResource Subtle}" FontSize="12" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding Login}" />
                                                <Run Text="•" />
                                                <Run Text="{Binding Database}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="Load" Click="LoadConnection_Click"
                                                Tag="{Binding}" VerticalAlignment="Center"
                                                ToolTipService.ToolTip="Load onto the Deploy form" />

                                        <Button Grid.Column="3" Click="DeleteConnection_Click" Tag="{Binding}"
                                                VerticalAlignment="Center" Padding="8"
                                                Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Delete this saved connection">
                                            <FontIcon Glyph="&#xE74D;" FontSize="15" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </tk:SettingsExpander.ItemsHeader>
            </tk:SettingsExpander>

            <!-- ============ UPDATES ============ -->
            <tk:SettingsCard Header="Updates"
                             Description="Check GitHub for a newer version.">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;" />
                </tk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateStatusText" VerticalAlignment="Center"
                               Style="{StaticResource Subtle}" FontSize="12" />
                    <ProgressRing x:Name="UpdateProgress" Width="18" Height="18"
                                  IsActive="False" Visibility="Collapsed" />
                    <Button x:Name="CheckUpdatesButton" Content="Check for updates"
                            Click="CheckUpdates_Click" />
                </StackPanel>
            </tk:SettingsCard>

            <!-- ============ ABOUT ============ -->
            <tk:SettingsExpander x:Name="AboutExpander" Header="About">
                <tk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </tk:SettingsExpander.HeaderIcon>
                <tk:SettingsExpander.ItemsHeader>
                        <StackPanel Spacing="18" Padding="16,12" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Image x:Name="AppLogo" Width="48" Height="48" VerticalAlignment="Top" />
                                <StackPanel Spacing="6" MaxWidth="620">
                                    <TextBlock Text="SQL Deploy — Migration Console"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Subtle}"
                                               Text="Apply versioned SQL migration scripts to SQL Server with dependency-aware ordering, deployment history, and one-time-apply safety. A modern WinUI re-design of the original WinForms deployment tool." />
                                    <TextBlock x:Name="VersionLine" Style="{StaticResource Subtle}"
                                               FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
                                    <muxc:PersonPicture x:Name="SabarishPhoto" Width="64" Height="64"
                                                        VerticalAlignment="Top" />
                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="Sabarish" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Developer" Style="{StaticResource Subtle}" FontSize="12" />
                                        <HyperlinkButton Content="LinkedIn ↗" Padding="0,2"
                                                         NavigateUri="https://www.linkedin.com/in/sabarish55/" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                                    <muxc:PersonPicture x:Name="JaganPhoto" Width="64" Height="64"
                                                        VerticalAlignment="Top" />
                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="Jagan Murugaiyan" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Developer" Style="{StaticResource Subtle}" FontSize="12" />
                                        <HyperlinkButton Content="LinkedIn ↗" Padding="0,2"
                                                         NavigateUri="https://www.linkedin.com/in/jaganedits/" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Developed &amp; re-designed by Sabarish and Jagan Murugaiyan."
                                       Style="{StaticResource Subtle}" FontSize="12" />
                        </StackPanel>
                </tk:SettingsExpander.ItemsHeader>
            </tk:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</Page>
