<Application
    x:Class="SqlDeployerGui.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared surface for grouped content (connection card, output panel, etc.) -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource CardPadding}" />
            </Style>

            <!-- Tracked all-caps label that opens each section of a card -->
            <Style x:Key="SectionCaption" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="CharacterSpacing" Value="90" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Muted helper / subtitle copy -->
            <Style x:Key="Subtle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
